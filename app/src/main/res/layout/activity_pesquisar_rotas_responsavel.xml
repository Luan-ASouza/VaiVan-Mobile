<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER -->

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F6B12F"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtBoasVindas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Bem vinda, Marina"
                android:textColor="#1E1E1E"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/imgPerfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/sym_def_app_icon"/>
        </LinearLayout>

    </LinearLayout>

    <!-- CONTEÚDO -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TÍTULO -->

            <TextView
                android:id="@+id/txtPesquisarRotas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:text="Pesquisar Rotas"
                android:textColor="#1E1E1E"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- CARD -->

            <LinearLayout
                android:id="@+id/cardRotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E4DBD4"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- PASSAGEIRO -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Passageiro"
                    android:textColor="#1E1E1E"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/sym_def_app_icon"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lucas Santos"
                            android:textColor="#1E1E1E"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11 anos"
                            android:textColor="#1E1E1E"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- EMBARQUE -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Endereço de embarque"
                    android:textColor="#1E1E1E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/edtEmbarque"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#FFFFFF"
                    android:hint="Rua das Palmeiras, 245 – Apto 32"
                    android:padding="12dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#AFAFAF"/>

                <!-- DESEMBARQUE -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Endereço de desembarque"
                    android:textColor="#1E1E1E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/edtDesembarque"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#FFFFFF"
                    android:hint="La Salle Carmo"
                    android:padding="12dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#AFAFAF"/>

                <!-- TURNO -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Turno"
                    android:textColor="#1E1E1E"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Manhã"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTarde"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Tarde"
                        android:textAllCaps="false"
                        app:backgroundTint="#D9D9D9"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNoite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Noite"
                        android:textAllCaps="false"
                        app:backgroundTint="#D9D9D9"/>

                </LinearLayout>

                <!-- DIAS -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Dias da Semana"
                    android:textColor="#1E1E1E"
                    android:textStyle="bold"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSegunda"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Segunda"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTerca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Terça"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuarta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Quarta"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuinta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Quinta"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSexta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Sexta"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E1E1E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSabado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Sábado"
                        android:textAllCaps="false"
                        app:backgroundTint="#D9D9D9"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDomingo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:text="Domingo"
                        android:textAllCaps="false"
                        app:backgroundTint="#D9D9D9"/>

                </GridLayout>

                <!-- HORÁRIO -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Horário de Embarque"
                    android:textColor="#1E1E1E"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtHoraInicio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#FFFFFF"
                        android:hint="6:30"
                        android:padding="12dp"
                        android:textColor="#1E1E1E"
                        android:textColorHint="#AFAFAF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:text="e"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/edtHoraFim"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#FFFFFF"
                        android:hint="7:20"
                        android:padding="12dp"
                        android:textColor="#1E1E1E"
                        android:textColorHint="#AFAFAF"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- MENU INFERIOR -->

    <LinearLayout
        android:id="@+id/bottomMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Passageiros"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_directions"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rotas"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_dialog_email"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_manage"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>