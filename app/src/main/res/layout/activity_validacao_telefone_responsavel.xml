<?xml version="1.0" encoding="utf-8"?>

<!-- TELA COMPLETA COM ROLAGEM -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- CONTAINER PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="36dp"
        android:paddingTop="200dp">

        <!-- TÍTULO DA TELA -->
        <TextView
            android:id="@+id/txtTituloValidacaoTelefone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Validação de Telefone"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- TEXTO EXPLICATIVO -->
        <TextView
            android:id="@+id/txtInstrucaoTelefone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enviamos um código para seu telefone.\nDigite abaixo para continuar."
            android:textColor="#777777"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="26dp" />

        <!-- CONTAINER DOS CAMPOS DO CÓDIGO -->
        <LinearLayout
            android:id="@+id/layoutCodigoTelefone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <!-- CAMPO CÓDIGO 1 -->
            <EditText
                android:id="@+id/editTelefoneCodigo1"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CAMPO CÓDIGO 2 -->
            <EditText
                android:id="@+id/editTelefoneCodigo2"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CAMPO CÓDIGO 3 -->
            <EditText
                android:id="@+id/editTelefoneCodigo3"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CAMPO CÓDIGO 4 -->
            <EditText
                android:id="@+id/editTelefoneCodigo4"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- LINHA DE ERRO E REENVIO -->
        <LinearLayout
            android:id="@+id/layoutMensagensTelefone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- MENSAGEM DE ERRO -->
            <TextView
                android:id="@+id/txtErroCodigoTelefone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="*Código inválido ou expirado."
                android:textColor="#E53935"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- TEXTO REENVIAR CÓDIGO -->
            <TextView
                android:id="@+id/txtReenviarCodigoTelefone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reenviar código"
                android:textColor="#111111"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- BOTÃO CONTINUAR -->
        <Button
            android:id="@+id/btnContinuarValidacaoTelefone"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="42dp"
            android:background="@drawable/btn_black_white_selector"
            android:backgroundTint="@null"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>