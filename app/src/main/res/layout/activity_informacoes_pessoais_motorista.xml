<?xml version="1.0" encoding="utf-8"?>

<!-- TELA COMPLETA COM ROLAGEM -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- CONTAINER PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TÍTULO DA TELA -->
        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informações pessoais"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp" />

        <!-- LABEL NOME COMPLETO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome Completo"
            android:textStyle="bold"
            android:textSize="14sp" />

        <!-- CAMPO NOME COMPLETO -->
        <EditText
            android:id="@+id/editNome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_white"
            android:paddingHorizontal="16dp"
            android:textSize="16sp"
            android:inputType="textPersonName" />

        <!-- LABEL CPF -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <!-- CAMPO CPF COM BORDA VERMELHA -->
        <EditText
            android:id="@+id/editCpf"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_white_red"
            android:paddingHorizontal="16dp"
            android:textSize="16sp"
            android:inputType="number" />

        <!-- MENSAGEM DE ERRO DO CPF -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*Digite um CPF válido.\n*CPF já cadastrado no sistema."
            android:lineSpacingExtra="4dp"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <!-- LABEL DATA DE NASCIMENTO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data de nascimento"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="20dp" />

        <!-- CONTAINER DOS CAMPOS DIA, MÊS E ANO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- CAMPO DIA -->
            <Spinner
                android:id="@+id/spinnerDia"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_white_red"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown" />

            <!-- CAMPO MÊS -->
            <Spinner
                android:id="@+id/spinnerMes"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_white_red"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown" />

            <!-- CAMPO ANO -->
            <Spinner
                android:id="@+id/spinnerAno"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_white_red"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown" />

        </LinearLayout>

        <!-- MENSAGEM DE ERRO DA DATA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*Obrigatório ser maior de 21 anos"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <!-- BOTÃO CONTINUAR -->
        <Button
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_button_black"
            android:backgroundTint="@null"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>