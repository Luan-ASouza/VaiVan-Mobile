<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TÍTULO -->

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informações pessoais"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"/>

        <!-- NOME -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome Completo"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/editNome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_white"
            android:paddingHorizontal="16dp"
            android:textSize="16sp"
            android:inputType="text"/>

        <!-- CPF -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editCpf"
            android:paddingHorizontal="16dp"
            android:textSize="16sp"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:background="bg_input_white_red"
            android:paddingStart="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*Digite um CPF válido.\n*CPF já cadastrado no sistema."
            android:lineSpacingExtra="4dp"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <!-- DATA NASCIMENTO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data de nascimento"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- DIA -->

            <Spinner
                android:id="@+id/spinnerDia"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="bg_input_white_red"/>

            <!-- MÊS -->

            <Spinner
                android:id="@+id/spinnerMes"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="bg_input_white_red"/>

            <!-- ANO -->

            <Spinner
                android:id="@+id/spinnerAno"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="bg_input_white_red"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*Obrigatório ser maior de 21 anos"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <!-- BOTÃO -->

        <Button
            android:id="@+id/btnContinuar"
            android:backgroundTint="@null"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_button_black"/>

    </LinearLayout>

</ScrollView>