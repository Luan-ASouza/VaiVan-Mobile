<?xml version="1.0" encoding="utf-8"?>

<!-- TELA COMPLETA COM ROLAGEM -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- CONTAINER PRINCIPAL DA TELA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="36dp"
        android:paddingTop="210dp">

        <!-- TÍTULO DA TELA -->
        <TextView
            android:id="@+id/txtTituloAutorizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autorização"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!-- TEXTO EXPLICATIVO -->
        <TextView
            android:id="@+id/txtDescricaoAutorizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Envie sua autorização para transporte escolar."
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="60dp" />

        <!-- LABEL FOTO DA AUTORIZAÇÃO -->
        <TextView
            android:id="@+id/txtFotoAutorizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto da autorização"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="8dp" />

        <!-- LINHA COM BOTÃO EDITAR ENVIO E NOME DO ARQUIVO -->
        <LinearLayout
            android:id="@+id/layoutArquivoAutorizacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="62dp">

            <!-- BOTÃO EDITAR ENVIO -->
            <Button
                android:id="@+id/btnEditarEnvioAutorizacao"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/btn_black_white_selector"
                android:backgroundTint="@null"
                android:text="Editar envio"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <!-- NOME DO ARQUIVO ENVIADO -->
            <TextView
                android:id="@+id/txtNomeArquivoAutorizacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="nomedoArquivo.png"
                android:textColor="#111111"
                android:textSize="12sp"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- BOTÃO PRINCIPAL CONTINUAR -->
        <Button
            android:id="@+id/btnContinuarAutorizacao"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/btn_black_white_selector"
            android:backgroundTint="@null"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>