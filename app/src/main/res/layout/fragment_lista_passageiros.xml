<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">


    <TextView
        android:id="@+id/labelPassageiros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Seus Passageiros"
        android:textColor="@color/dark_gray"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText" />

    <LinearLayout
        android:id="@+id/containerLista"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnNovoPassageiro"
        app:layout_constraintTop_toBottomOf="@id/labelPassageiros">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/beige"
            app:cardCornerRadius="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgFotoPassageiro1"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="2dp"

                    android:src="@drawable/filho1"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/dark_gray"
                    app:strokeWidth="3dp"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtNome2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Lucas Santos"
                    android:textColor="@color/dark_gray"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgFotoPassageiro1"
                    app:layout_constraintTop_toTopOf="@id/imgFotoPassageiro1"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11 anos"
                    android:textColor="#707070"
                    app:layout_constraintStart_toStartOf="@id/txtNome2"
                    app:layout_constraintTop_toBottomOf="@id/txtNome2"
                    tools:ignore="HardcodedText" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="Pendentes"
            android:textColor="@color/dark_gray"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/beige"
            app:cardCornerRadius="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgFotoPassageiro2"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="2dp"

                    android:src="@drawable/jovem1"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/dark_gray"
                    app:strokeWidth="3dp"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtNome1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="João Miguel"
                    android:textColor="@color/dark_gray"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgFotoPassageiro2"
                    app:layout_constraintTop_toTopOf="@id/imgFotoPassageiro2"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19 anos"
                    android:textColor="#707070"
                    app:layout_constraintStart_toStartOf="@id/txtNome1"
                    app:layout_constraintTop_toBottomOf="@id/txtNome1"
                    tools:ignore="HardcodedText" />

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/FlowBotoes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"

                    app:constraint_referenced_ids="btnAceitar, btnRecusar"
                    app:flow_horizontalGap="10dp"

                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/imgFotoPassageiro2" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAceitar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_green"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:text="Aceitar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/FlowBotoes"
                    app:layout_constraintStart_toStartOf="@+id/FlowBotoes"
                    app:layout_constraintTop_toTopOf="@+id/FlowBotoes" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRecusar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_red"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="8dp"
                    android:text="Recusar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@+id/FlowBotoes"
                    app:layout_constraintBottom_toBottomOf="@+id/FlowBotoes"
                    app:layout_constraintEnd_toEndOf="@+id/FlowBotoes" />
            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.cardview.widget.CardView>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnNovoPassageiro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@drawable/bg_beige_round_20"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="15dp"

        android:clickable="true"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/rego8jf4ll7m"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar Passageiro"
            android:textColor="@color/dark_gray"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/r05o09rcd62wo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:scaleType="fitXY"
            android:src="@drawable/ic_plus" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>