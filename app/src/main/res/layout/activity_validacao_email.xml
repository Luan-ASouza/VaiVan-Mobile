<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minHeight="700dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="36dp">

        <TextView
            android:id="@+id/txtTituloValidacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Validação de Email"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="210dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txtInstrucao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enviamos um código para seu e-mail.\nDigite abaixo para continuar."
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="26dp" />

        <LinearLayout
            android:id="@+id/layoutCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/editCodigo1"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:text="6"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCodigo2"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:text="8"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCodigo3"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:text="2"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCodigo4"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_code_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:text="4"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutMensagens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtErroCodigo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="*Código inválido ou expirado."
                android:textColor="#E53935"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtReenviarCodigo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reenviar código"
                android:textColor="#111111"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paintFlags="underline" />

        </LinearLayout>

        <Button
            android:id="@+id/btnContinuarValidacao"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="42dp"
            android:background="@drawable/bg_button_black"
            android:backgroundTint="@null"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>