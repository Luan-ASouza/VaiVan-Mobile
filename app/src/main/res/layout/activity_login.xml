<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".LoginActivity">

    <!-- Fundo amarelo diagonal -->
    <View
        android:id="@+id/viewYellow"
        android:layout_width="260dp"
        android:layout_height="900dp"
        android:background="#F5B42D"
        android:rotation="-20"
        android:translationX="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Logo -->
    <TextView
        android:id="@+id/txtVai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAI"
        android:textStyle="bold"
        android:textSize="34sp"
        android:textColor="#000000"
        android:layout_marginTop="90dp"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtVane"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VANE"
        android:textStyle="bold"
        android:textSize="34sp"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/txtVai"
        app:layout_constraintStart_toEndOf="@id/txtVai"/>

    <ImageView
        android:id="@+id/imgTruck"
        android:layout_width="81dp"
        android:layout_height="132dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="72dp"
        android:alpha="0.95"
        android:src="@drawable/ic_truck"
        app:layout_constraintStart_toEndOf="@+id/txtVane"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAI CONTIGO!"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/txtVai"
        app:layout_constraintStart_toStartOf="@id/txtVai"/>

    <!-- Card Login -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtSlogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrar"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"/>

            <!-- Email -->
            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Email"
                android:paddingStart="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="textEmailAddress"
                android:drawablePadding="10dp"/>

            <!-- Senha -->
            <EditText
                android:id="@+id/edtSenha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:hint="Senha"
                android:paddingStart="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="textPassword"/>

            <!-- Esqueci senha -->
            <TextView
                android:id="@+id/txtEsqueci"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esqueci minha senha"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"/>

            <!-- Botão Entrar -->
            <Button
                android:id="@+id/btnEntrar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:text="Entrar"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_yellow"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>