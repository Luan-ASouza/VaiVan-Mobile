<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_gray"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/layoutContainerPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_white_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgConstrucao"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_construction"
            app:tint="@color/dark_gray" />

        <TextView
            android:id="@+id/txtTituloDesenvolvimento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Área de Motoristas"
            android:textAlignment="center"
            android:textColor="@color/dark_gray"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtStatusDesenvolvimento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Funcionalidade em desenvolvimento"
            android:textAlignment="center"
            android:textColor="@color/dark_gray"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAvisoIlustrativo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Em breve você poderá gerenciar suas rotas e clientes."
            android:textAlignment="center"
            android:textColor="@color/dark_gray"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>