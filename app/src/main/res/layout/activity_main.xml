<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- Faixa Amarela -->
    <View
        android:id="@+id/viewYellow"
        android:layout_width="260dp"
        android:layout_height="900dp"
        android:background="#F5B42D"
        android:rotation="-20"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="120dp"/>

    <!-- Logo -->
    <TextView
        android:id="@+id/txtVai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAI"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="34sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="40dp"
        android:layout_marginTop="120dp"/>

    <TextView
        android:id="@+id/txtVane"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VANE"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="34sp"
        app:layout_constraintTop_toTopOf="@id/txtVai"
        app:layout_constraintStart_toEndOf="@id/txtVai"/>

    <TextView
        android:id="@+id/txtSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VAI CONTIGO!"
        android:textStyle="bold"
        android:textColor="#000000"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/txtVai"
        app:layout_constraintStart_toStartOf="@id/txtVai"/>

    <!-- Ícone caminhão -->

    <!-- Botão Entrar -->

    <ImageView
        android:id="@+id/imgTruck"
        android:layout_width="81dp"
        android:layout_height="132dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="96dp"
        android:alpha="0.95"
        android:src="@drawable/ic_truck"
        app:layout_constraintStart_toEndOf="@+id/txtVane"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Entrar"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_black"
        app:layout_constraintBottom_toTopOf="@id/btnCadastrar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="35dp"
        android:layout_marginEnd="35dp"
        android:layout_marginBottom="16dp"/>

    <!-- Botão Cadastro -->
    <Button
        android:id="@+id/btnCadastrar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Cadastrar nova conta"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#000000"
        android:background="@drawable/bg_button_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="35dp"
        android:layout_marginEnd="35dp"
        android:layout_marginBottom="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>