<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/r5bytuqfatu5"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:paddingVertical="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rot06mq85vr8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Suas Conversas"
            android:textColor="@color/dark_gray"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/r2xflm6ba2je"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/linearLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Item de conversa 1 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/r24dtccizf3f"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_beige_round_20"
                    android:elevation="4dp"
                    android:padding="10dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgContato1"
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/homem1_avatar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="@color/dark_gray"
                        app:strokeWidth="2dp" />

                    <TextView
                        android:id="@+id/txtNomeContato1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Douglas Silva"
                        android:textColor="@color/dark_gray"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/txtDataContato1"
                        app:layout_constraintStart_toEndOf="@+id/imgContato1"
                        app:layout_constraintTop_toTopOf="@+id/imgContato1" />

                    <TextView
                        android:id="@+id/txtDataContato1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17/04/2026"
                        android:textColor="@color/dark_gray"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/imgContato1" />

                    <TextView
                        android:id="@+id/txtRotaContato1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Douglas Transporte"
                        android:textColor="@color/dark_gray"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/txtNomeContato1"
                        app:layout_constraintTop_toBottomOf="@+id/txtNomeContato1" />

                    <TextView
                        android:id="@+id/txtMensagem1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Olá. Me chamo Marina e gostari..."
                        android:textColor="@color/dark_gray"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@+id/imgContato1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/txtNomeContato1"
                        app:layout_constraintTop_toBottomOf="@+id/txtRotaContato1" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Item de conversa 2 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/rnl4umafso2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_beige_round_20"
                    android:elevation="4dp"
                    android:padding="10dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgContato2"
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/homem2_avatar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="@color/dark_gray"
                        app:strokeWidth="2dp" />

                    <TextView
                        android:id="@+id/txtNomeContato2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Leandro Oliveira"
                        android:textColor="@color/dark_gray"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/txtDataContato2"
                        app:layout_constraintStart_toEndOf="@+id/imgContato2"
                        app:layout_constraintTop_toTopOf="@+id/imgContato2" />

                    <TextView
                        android:id="@+id/txtDataContato2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17/04/2026"
                        android:textColor="@color/dark_gray"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/imgContato2" />

                    <TextView
                        android:id="@+id/txtRotaContato2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Leandro Viagens"
                        android:textColor="@color/dark_gray"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/txtNomeContato2"
                        app:layout_constraintTop_toBottomOf="@+id/txtNomeContato2" />

                    <TextView
                        android:id="@+id/txtMensagem2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Olá. Me chamo Marina e gostari..."
                        android:textColor="@color/dark_gray"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@+id/imgContato2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/txtNomeContato2"
                        app:layout_constraintTop_toBottomOf="@+id/txtRotaContato2" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/textView3"
                android:layout_width="match_parent"

                android:layout_height="wrap_content"
                android:text="Funcionalidade em desenvolvimento"
                android:textAlignment="center"
                android:textColor="@color/dark_gray"
                android:textSize="30dp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/textView2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="40dp"

                android:src="@drawable/ic_construction"
                android:tint="@color/orange"

                app:layout_constraintBottom_toTopOf="@+id/textView3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"

                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="68dp"
                android:text="Itens nessa página são meramente ilustrativos."
                android:textAlignment="center"
                android:textColor="@color/dark_gray"
                android:textSize="20dp"
                android:textStyle=""
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>